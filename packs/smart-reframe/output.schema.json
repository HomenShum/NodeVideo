{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "assetId",
    "intent",
    "cropKeyframes",
    "confidenceByRange",
    "trackingLossRanges",
    "manualOverrides",
    "sourceTrackId"
  ],
  "properties": {
    "schemaVersion": { "const": "nodevideo.smart-reframe.v1" },
    "id": { "type": "string" },
    "assetId": { "type": "string" },
    "intent": { "type": "object" },
    "cropKeyframes": { "type": "array", "minItems": 1 },
    "confidenceByRange": { "type": "array" },
    "trackingLossRanges": { "type": "array" },
    "manualOverrides": { "type": "array" },
    "sourceTrackId": { "type": "string" }
  },
  "additionalProperties": false
}
