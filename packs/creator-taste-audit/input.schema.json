{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodevideo.local/schemas/creator-taste-audit/input.v1.json",
  "title": "Creator taste learning or production audit request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestId", "projectId", "mode", "contentKind"],
  "properties": {
    "schemaVersion": { "const": "nodevideo.creator-taste-request.v1" },
    "requestId": { "$ref": "#/$defs/id" },
    "projectId": { "$ref": "#/$defs/id" },
    "mode": { "enum": ["learn", "audit", "reuse"] },
    "contentKind": {
      "enum": ["dance", "talking-head", "tutorial", "comedy", "montage", "other"]
    },
    "productionAuditArtifactIds": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1000,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/id" }
    },
    "creatorTasteProfileArtifactId": { "$ref": "#/$defs/id" },
    "candidateProductionAuditArtifactId": { "$ref": "#/$defs/id" }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "learn" } }, "required": ["mode"] },
      "then": { "required": ["productionAuditArtifactIds"] }
    },
    {
      "if": { "properties": { "mode": { "enum": ["audit", "reuse"] } }, "required": ["mode"] },
      "then": {
        "required": ["creatorTasteProfileArtifactId", "candidateProductionAuditArtifactId"]
      }
    }
  ],
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    }
  }
}
