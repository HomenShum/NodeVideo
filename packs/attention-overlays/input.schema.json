{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nodevideo.local/schemas/attention-overlays/input.v1.json",
  "title": "Attention overlay generation request",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "requestId", "videoArtifactId", "poseArtifactId", "cues"],
  "properties": {
    "schemaVersion": { "const": "nodevideo.attention-overlay-request.v1" },
    "requestId": { "$ref": "#/$defs/id" },
    "videoArtifactId": { "$ref": "#/$defs/id" },
    "poseArtifactId": { "$ref": "#/$defs/id" },
    "gradeKind": {
      "enum": [
        "auto",
        "none",
        "hlg-bt2020-to-sdr-bt709-hable",
        "hlg-bt2020-to-sdr-bt709-creator-vibrant",
        "hlg-bt2020-to-sdr-bt709-creator-dark-warm",
        "hlg-bt2020-to-sdr-bt709-creator-social-vivid"
      ],
      "default": "auto"
    },
    "numPoses": { "type": "integer", "minimum": 1, "maximum": 10, "default": 6 },
    "canvasMode": { "enum": ["source", "vertical"], "default": "source" },
    "maxBodyOverlapRatio": { "type": "number", "minimum": 0, "maximum": 0.05, "default": 0.05 },
    "cues": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/cue" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "cue": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text", "startSeconds", "endSeconds"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "text": { "type": "string", "minLength": 1, "maxLength": 280 },
        "startSeconds": { "type": "number", "minimum": 0 },
        "endSeconds": { "type": "number", "exclusiveMinimum": 0 },
        "role": { "enum": ["attention", "identity"], "default": "attention" },
        "animation": { "enum": ["none", "fade", "pop", "slide-up"] }
      }
    }
  }
}
