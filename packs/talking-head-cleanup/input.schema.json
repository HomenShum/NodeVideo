{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["mediaIndexId", "intentId", "pausePolicy"],
  "properties": {
    "mediaIndexId": { "type": "string", "minLength": 1 },
    "intentId": { "type": "string", "minLength": 1 },
    "pausePolicy": { "enum": ["tight", "natural", "presentation"] },
    "removeFillers": { "type": "boolean" }
  },
  "additionalProperties": false
}
