{
  "name": "nodevideo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A privacy-first, inspectable video reconstruction workspace.",
  "scripts": {
    "dev": "vite",
    "demo": "npm run dev",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "capability:validate": "node scripts/quality/validate-capability-pack.mjs",
    "doctor": "npm run capability:validate && npm run worker:verify",
    "worker:public": "node scripts/workers/tutorial-compare.mjs --public",
    "worker:verify": "node scripts/workers/tutorial-compare.mjs --verify-public",
    "worker:private": "node scripts/workers/tutorial-compare.mjs",
    "worker:authorized": "node scripts/workers/reference-reconstruct.mjs --authorized-public",
    "worker:authorized:verify": "node scripts/workers/reference-reconstruct.mjs --verify-public",
    "worker:edit-plan": "node scripts/workers/edit-plan-renderer.mjs",
    "proof:synthetic": "node scripts/media/generate-synthetic-fixture.mjs",
    "proof": "npm run worker:verify",
    "proof:private": "node scripts/media/inspect-private-media.mjs",
    "proof:private:render": "node scripts/media/render-private-reconstruction.mjs",
    "qa:capture": "node scripts/qa/capture-ui.mjs",
    "ui:policy": "node scripts/quality/check-ui-policy.mjs",
    "ui:budget": "node scripts/quality/check-ui-budget.mjs",
    "check:ui": "npm run ui:policy && npm run ui:budget",
    "check": "npm run lint && npm run typecheck && npm run test && npm run check:ui && npm run capability:validate && npm run worker:verify && npm run worker:authorized:verify && npm run build",
    "qa": "npm run check && npm run proof:synthetic && npm run test:e2e"
  },
  "dependencies": {
    "@assistant-ui/react-o11y": "0.0.25",
    "@assistant-ui/store": "0.2.19",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "ai": "^7.0.28",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.42.2",
    "lucide-react": "^1.12.0",
    "radix-ui": "^1.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.3.1",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "playwright": "^1.59.1",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
