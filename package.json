{
  "name": "nodevideo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A privacy-first, inspectable video reconstruction workspace.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "proof:synthetic": "node scripts/media/generate-synthetic-fixture.mjs",
    "proof:private": "node scripts/media/inspect-private-media.mjs",
    "proof:private:render": "node scripts/media/render-private-reconstruction.mjs",
    "qa:capture": "node scripts/qa/capture-ui.mjs",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "qa": "npm run check && npm run proof:synthetic && npm run test:e2e"
  },
  "dependencies": {
    "@assistant-ui/react-o11y": "0.0.25",
    "@assistant-ui/store": "0.2.19",
    "clsx": "^2.1.1",
    "lucide-react": "^1.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@axe-core/playwright": "^4.12.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "jsdom": "^29.1.1",
    "playwright": "^1.59.1",
    "typescript": "^5.7.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
