{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": [
      "dist",
      "node_modules",
      "apps/eve-agent/.eve",
      "apps/eve-agent/.output",
      "apps/eve-agent/.nitro",
      "apps/eve-agent/node_modules",
      "playwright-report",
      "test-results",
      ".qa/cache",
      ".qa/evidence",
      ".qa/media",
      ".qa/models",
      ".vercel",
      "fixtures/media/tutorial-compare-v1",
      "fixtures/media/authorized-real-v1",
      "fixtures/media/authorized-real-v2",
      "fixtures/media/blind-source-only-pilot-01",
      "fixtures/media/song-conditioned-auto-edit-v1",
      "fixtures/media/song-conditioned-real-calibration-v1",
      "fixtures/media/integrated-source-only-v1",
      "convex/_generated",
      "src/styles.css",
      "src/components/ui",
      "src/components/ai-elements"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "overrides": [
    {
      "include": ["src/lib/workflowExecutionPort.ts"],
      "formatter": { "enabled": false },
      "linter": {
        "rules": {
          "complexity": { "useLiteralKeys": "off" }
        }
      }
    }
  ]
}
