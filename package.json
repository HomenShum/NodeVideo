{
  "name": "nodevideo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A privacy-first, inspectable video reconstruction workspace.",
  "scripts": {
    "dev": "vite",
    "demo": "npm run dev",
    "build": "tsc --noEmit && vite build && node scripts/quality/copy-mediapipe-wasm.mjs && node scripts/quality/copy-ffmpeg-wasm.mjs && node scripts/quality/stamp-contract-build.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:creator": "vitest run src/lib/founder-content.test.ts src/lib/recipe-compiler.test.ts src/lib/founder-variant-compiler.test.ts src/lib/template-vault.test.ts",
    "proof:creator": "npm run test:creator && playwright test tests/e2e/creator-pipeline.spec.ts --project=desktop-chromium --project=mobile-chromium",
    "proof:caseflow": "node scripts/qa/write-nodekit-consumer-proof.mjs",
    "proof:creator:receipt": "node scripts/qa/write-nodekit-consumer-proof.mjs",
    "creator:dev": "vite --open /creator.html",
    "creatorbench:dev": "vite --open /creatorbench",
    "creatorbench:acquire": "node scripts/benchmarks/acquire-creatorbench.mjs --download",
    "creatorbench:discover": "node scripts/benchmarks/acquire-creatorbench.mjs --discover-only",
    "creatorbench:manifests": "node scripts/benchmarks/build-creatorbench-manifests.mjs",
    "creatorbench:dedupe": "node scripts/benchmarks/deduplicate-creatorbench.mjs",
    "creatorbench:validate": "node scripts/benchmarks/validate-creatorbench.mjs",
    "creatorbench:evaluate": "node scripts/benchmarks/evaluate-creatorbench.mjs",
    "creatorbench:public": "npm run creatorbench:manifests && npm run creatorbench:dedupe && npm run creatorbench:validate && npm run creatorbench:evaluate",
    "creatorbench:evaluate:sealed": "node scripts/benchmarks/evaluate-creatorbench.mjs --sealed",
    "creatorbench:freeze": "node scripts/benchmarks/freeze-creatorbench.mjs",
    "creatorbench:publish": "node scripts/benchmarks/publish-creatorbench-report.mjs",
    "creatorbench:report": "npm run creatorbench:publish",
    "creatorbench:claims": "npm run creatorbench:publish",
    "creatorbench:compare": "node scripts/benchmarks/compare-creatorbench-releases.mjs",
    "creatorbench:proof:verify": "node scripts/quality/verify-creatorbench-public-proof.mjs",
    "proof:creatorbench": "npm run creatorbench:validate && playwright test tests/e2e/creatorbench.spec.ts --project=desktop-chromium --project=mobile-chromium",
    "media:index": "node scripts/workers/local-media-indexer.mjs",
    "media:index:doctor": "node scripts/workers/local-media-indexer.mjs --verify",
    "creator:local": "node scripts/workers/creator-pipeline-local.mjs",
    "higgsfield:doctor": "node scripts/providers/higgsfield-cli.mjs doctor",
    "higgsfield:models": "node scripts/providers/higgsfield-cli.mjs models",
    "higgsfield:run": "node scripts/providers/higgsfield-cli.mjs run",
    "higgsfield:benchmark:plan": "node scripts/providers/build-higgsfield-benchmark.mjs",
    "higgsfield:benchmark:score": "node scripts/providers/score-higgsfield-benchmark.mjs",
    "executors:doctor": "node scripts/quality/doctor-specialist-executors.mjs",
    "asset:approve": "node scripts/artifacts/approve-asset-receipt.mjs",
    "showcase:build": "node scripts/showcase/build-showcase.mjs",
    "tracking:packs": "node scripts/domain/generate-tracking-packs.mjs",
    "atlas:build": "python scripts/media/build_tracking_atlas.py",
    "atlas:verify": "node scripts/quality/verify-tracking-atlas.mjs",
    "proof:atlas": "npm run atlas:verify && playwright test tests/e2e/tracking-atlas.spec.ts --project=desktop-chromium --project=mobile-chromium",
    "capability:validate": "node scripts/quality/validate-capability-pack.mjs",
    "check:bloat": "node scripts/quality/check-repo-bloat.mjs",
    "check:contract": "node scripts/quality/verify-ui-contract.mjs",
    "doctor": "npm run capability:validate && npm run grounding:doctor && npm run worker:verify && npm run worker:song:verify",
    "grounding:doctor": "node scripts/quality/grounding-doctor.mjs",
    "grounding:sidecar": "node --env-file-if-exists=.env scripts/grounding/locate-anything-sidecar.mjs",
    "grounding:proof": "node scripts/grounding/generate-locate-anything-proof.mjs",
    "grounding:proof:verify": "node scripts/quality/verify-locate-anything-proof.mjs",
    "coach:sidecar": "node --env-file-if-exists=.env scripts/workers/choreography-coach-sidecar.mjs",
    "coach:test": "python scripts/analysis/test_choreography_judge.py",
    "coach:calibrate": "python scripts/analysis/calibrate_choreography_judge.py",
    "extension:dev": "vite --config apps/chrome-extension/vite.config.ts",
    "extension:build": "vite build --config apps/chrome-extension/vite.config.ts",
    "taste:audit": "node scripts/analysis/creator-taste-profiler.mjs",
    "taste:intent:audit": "node scripts/analysis/production-decision-auditor.mjs",
    "taste:intent:learn": "node scripts/analysis/creator-intent-profiler.mjs",
    "audio:production:audit": "node scripts/analysis/audio-production-audit.mjs",
    "taste:evaluate": "node scripts/quality/evaluate-creative-fidelity.mjs",
    "production:verdicts": "node scripts/quality/evaluate-production-verdicts.mjs",
    "production:audit": "python scripts/analysis/production_style_audit.py",
    "overlay:refine": "node scripts/analysis/apply_overlay_refinement.mjs",
    "delivery:refine": "node scripts/analysis/apply_creator_delivery_profile.mjs",
    "overlay:clearance": "python scripts/analysis/audit_overlay_body_clearance.py",
    "overlay:attention:plan": "python scripts/analysis/plan_attention_overlays.py",
    "overlay:attention:render": "node scripts/workers/attention-overlay-private-render.mjs",
    "render:geometry-equivalence": "node scripts/analysis/verify_render_geometry_equivalence.mjs",
    "pipeline:gif": "python scripts/media/generate_pipeline_gif.py",
    "worker:grounding:verify": "npm run grounding:doctor",
    "eval:grounding": "npm run grounding:doctor",
    "worker:public": "node scripts/workers/tutorial-compare.mjs --public",
    "worker:verify": "node scripts/workers/tutorial-compare.mjs --verify-public",
    "worker:private": "node scripts/workers/tutorial-compare.mjs",
    "worker:authorized": "node scripts/workers/reference-reconstruct.mjs --authorized-public",
    "worker:authorized:verify": "node scripts/workers/reference-reconstruct.mjs --verify-public",
    "worker:edit-plan": "node scripts/workers/edit-plan-renderer.mjs",
    "worker:song:public": "node scripts/workers/song-conditioned-auto-edit.mjs --public",
    "worker:song:verify": "node scripts/workers/song-conditioned-auto-edit.mjs --verify-public",
    "worker:song:private": "node scripts/workers/song-conditioned-private-render.mjs",
    "eval:song": "node scripts/quality/evaluate-song-conditioned.mjs",
    "pilot:blind:evaluate": "node scripts/quality/evaluate-blind-pilot.mjs",
    "pilot:blind:publish": "node scripts/release/publish-blind-pilot.mjs",
    "proof:synthetic": "node scripts/media/generate-synthetic-fixture.mjs",
    "proof": "npm run worker:verify && npm run worker:song:verify && npm run proof:song:real:verify",
    "proof:song:public": "npm run worker:song:public && npm run worker:song:verify",
    "proof:choreography": "npm run worker:song:verify",
    "proof:song-conditioned": "npm run worker:song:verify",
    "proof:song:real:publish": "node scripts/release/publish-song-conditioned-calibration.mjs",
    "proof:song:real:verify": "node scripts/release/publish-song-conditioned-calibration.mjs --verify-public",
    "proof:private": "node scripts/media/inspect-private-media.mjs",
    "proof:private:render": "node scripts/media/render-private-reconstruction.mjs",
    "qa:capture": "node scripts/qa/capture-ui.mjs",
    "ui:policy": "node scripts/quality/check-ui-policy.mjs",
    "ui:budget": "node scripts/quality/check-ui-budget.mjs",
    "check:ui": "npm run ui:policy && npm run ui:budget",
    "check": "npm run lint && npm run typecheck && npm run test && npm run check:ui && npm run capability:validate && npm run atlas:verify && npm run grounding:doctor && npm run grounding:proof:verify && npm run worker:verify && npm run worker:song:verify && npm run proof:song:real:verify && npm run worker:authorized:verify && npm run build && npm run check:contract",
    "qa": "npm run check && npm run proof:synthetic && npm run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@assistant-ui/react-o11y": "0.0.25",
    "@assistant-ui/store": "0.2.19",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ffmpeg/core": "0.12.10",
    "@ffmpeg/core-mt": "0.12.10",
    "@ffmpeg/ffmpeg": "0.12.15",
    "@fontsource-variable/geist": "^5.2.9",
    "@gradio/client": "2.3.1",
    "@homenshum/nodekit": "github:HomenShum/node-platform#8d4f7e6e8235751d07c456208f841b15edf8de39",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@remotion/player": "^4.0.491",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "ai": "^7.0.28",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "convex": "^1.42.2",
    "lucide-react": "^1.12.0",
    "motion": "^12.42.2",
    "nanoid": "^6.0.0",
    "radix-ui": "^1.6.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-moveable": "^0.56.0",
    "remotion": "^4.0.491",
    "shiki": "^4.3.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "use-stick-to-bottom": "^1.1.6",
    "wavesurfer.js": "^7.12.11"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "^1.9.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "convex-test": "^0.0.54",
    "playwright": "^1.59.1",
    "shadcn": "^4.13.0",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
